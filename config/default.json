{
  "app": {
    "name": "Wedding Invitation Management",
    "version": "1.0.0",
    "description": "Wedding Invitation Management System for Event Planning and Guest Management"
  },
  "pagination": {
    "defaultLimit": 20,
    "maxLimit": 100
  },
  "guest": {
    "maxEventsPerGuest": 10,
    "defaultRsvpStatus": "pending"
  },
  "event": {
    "maxGuestsPerEvent": 500,
    "defaultEventDurationHours": 4
  },
  "invitation": {
    "invitationStatusPending": "pending",
    "invitationStatusAccepted": "accepted",
    "invitationStatusDeclined": "declined"
  }
}
